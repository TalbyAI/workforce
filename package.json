{
  "name": "talby-workforce",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm run check:code && pnpm run check:md",
    "check:code": "pnpm run check:types && pnpm run check:lint && pnpm run check:format",
    "check:types": "pnpm -r --if-present run typecheck",
    "check:format": "prettier --check .",
    "check:lint": "eslint .",
    "check:md": "markdownlint-cli2",
    "fix": "pnpm run fix:code && pnpm run fix:md",
    "fix:code": "pnpm run fix:types && pnpm run fix:lint && pnpm run fix:format",
    "fix:code:files": "node ./scripts/fix-code-files.mjs",
    "fix:types": "tsc --noEmit",
    "fix:format": "prettier --write .",
    "fix:lint": "eslint . --fix",
    "fix:md": "markdownlint-cli2 --fix",
    "fix:md:files": "node ./scripts/fix-md-files.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
