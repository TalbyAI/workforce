{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // baseUrl is deprecated in TypeScript 6.0 (to be removed in 7.0) but still
    // required for paths mapping. Silence the warning until we migrate.
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@talby/workforce-domain": ["packages/domain/src/index.ts"],
      "@talby/workforce-application": ["packages/application/src/index.ts"]
    }
  }
}
